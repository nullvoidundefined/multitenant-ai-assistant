{
  "name": "multitenant-worker",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "bullmq": "^5.52.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "multitenant-common": "workspace:*",
    "pg": "^8.18.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "prettier": "^3.8.1"
  }
